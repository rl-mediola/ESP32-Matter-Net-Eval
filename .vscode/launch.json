{
    "configurations": [
        {
            "name": "GDB",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/chip-lighting-app.elf",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            // "preLaunchTask": "OpenOCD",
            // "postDebugTask": "Stop OpenOCD",
            "MIMode": "gdb",
            "miDebuggerPath": "${env:HOME}/.espressif/tools/riscv32-esp-elf-gdb/16.3_20250913/riscv32-esp-elf-gdb/bin/riscv32-esp-elf-gdb",
            "setupCommands": [
                {
                    "description": "Connect to target",
                    "text": "source ${workspaceFolder}/build/gdbinit/gdbinit",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}